# DO NOT REMOVE. CLOUDLINUX PASSENGER CONFIGURATION BEGIN
PassengerAppRoot "/home/outgglmv/api.masalamatrix.com"
PassengerBaseURI "/"
PassengerNodejs "/home/outgglmv/nodevenv/api.masalamatrix.com/22/bin/node"
PassengerAppType node
PassengerStartupFile server.js
# DO NOT REMOVE. CLOUDLINUX PASSENGER CONFIGURATION END

Options -MultiViews
RewriteEngine On

# Allow all HTTP methods (PUT, PATCH, DELETE) required by the REST API
<IfModule mod_security.c>
  SecRuleEngine Off
</IfModule>

# Redirect HTTP to HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Block direct access to sensitive files
<FilesMatch "^(\.env|package\.json|package-lock\.json|README\.md)$">
  Order allow,deny
  Deny from all
</FilesMatch>

# Allow /uploads/ static files to be served directly by Apache
RewriteCond %{REQUEST_URI} ^/uploads/
RewriteRule ^ - [L]

# Route everything else to Node.js (Passenger)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ server.js [PassEnv,L]

# Security headers
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "DENY"
  Header always set X-XSS-Protection "1; mode=block"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Gzip for API responses
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE application/json
  AddOutputFilterByType DEFLATE text/plain
</IfModule>
